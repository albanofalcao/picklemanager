{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "picklemanager",
      "runtimeExecutable": "D:\\meuprojeto\\node\\node.exe",
      "runtimeArgs": ["-e", "const h=require('http'),fs=require('fs'),p=require('path');h.createServer((q,r)=>{let f=p.join('D:/meuprojeto',q.url==='/'?'/index.html':q.url.split('?')[0]);try{r.writeHead(200,{'Content-Type':({'html':'text/html','js':'application/javascript','css':'text/css','png':'image/png','jpg':'image/jpeg','svg':'image/svg+xml','ico':'image/x-icon','json':'application/json','woff2':'font/woff2','woff':'font/woff'}[f.split('.').pop()]||'text/plain')});fs.createReadStream(f).pipe(r)}catch{r.writeHead(404);r.end('Not found')}}).listen(3460)"],
      "port": 3460
    }
  ]
}
